<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <include layout="@layout/date_bubble" />

    <FrameLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|end"
            android:orientation="horizontal"
            android:paddingStart="68dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            tools:ignore="RtlSymmetry">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                tools:ignore="RtlSymmetry">

                <LinearLayout
                    android:id="@+id/messageBubble"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/message_avatar_size"
                    android:background="@drawable/chat_bubble_right"
                    android:backgroundTint="@color/colorMessageBubbleMine"
                    android:backgroundTintMode="multiply"
                    android:clickable="false"
                    android:elevation="@dimen/chat_bubble_elevation"
                    android:focusable="false"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/chat_bubble_padding_horizontal"
                    android:paddingTop="@dimen/chat_bubble_padding_vertical"
                    android:paddingEnd="@dimen/chat_bubble_tip_space"
                    android:paddingBottom="@dimen/chat_bubble_padding_vertical">

                    <co.tinode.tindroid.widgets.DynamicTextView
                        android:id="@+id/messageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="280dp"
                        android:minWidth="56dp"
                        android:textColor="?android:textColorPrimary"
                        tools:ignore="RtlSymmetry"
                        tools:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua." />

                    <include
                        android:id="@+id/progressContainer"
                        layout="@layout/progress_bar"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end">

                        <TextView
                            android:id="@+id/messageEdited"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp"
                            android:text="@string/edited"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="11sp"
                            android:textStyle="italic"
                            android:visibility="gone"
                            tools:ignore="SmallSp" />

                        <TextView
                            android:id="@+id/messageMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="2dp"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="11sp"
                            android:visibility="gone"
                            tools:ignore="SmallSp"
                            tools:text="12:17 PM" />

                        <ImageView
                            android:id="@+id/messageViewedIcon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center_vertical"
                            android:alpha="0.8"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp"
                            tools:ignore="ContentDescription,SmallSp"
                            tools:src="@drawable/ic_done_all" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar"
                android:layout_width="@dimen/message_avatar_size"
                android:layout_height="@dimen/message_avatar_size"
                android:contentDescription="@string/avatar"
                app:shapeAppearanceOverlay="@style/roundImageView"
                app:srcCompat="@drawable/ic_person_circle"
                app:strokeColor="@android:color/transparent" />
        </LinearLayout>

        <View
            android:id="@+id/selected"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/colorMessageSelected"
            android:clickable="false"
            android:focusable="false" />

        <View
            android:id="@+id/overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?android:selectableItemBackground"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>
</LinearLayout>
